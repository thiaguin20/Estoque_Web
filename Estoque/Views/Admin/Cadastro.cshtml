@model Estoque.Models.ViewModels.CadastroUsuarioViewModel

@{
    ViewBag.Title = "Cadastro";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cadastro - Marcenaria</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="@Url.Content("~/Content/bootstrap.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/Site.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/ViewStyles/admin-cadastro.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/ViewStyles/mobile.css")" rel="stylesheet" />
</head>
<body>
    <div class="split">
        <div class="panel-left">
            <div class="brand">
                <div class="brand-icon"><i class="bi bi-tools"></i></div>
                <div>
                    <strong>Marcenaria</strong><br />
                    <small class="text-muted-soft">Sistema de Gestao</small>
                </div>
            </div>

            <h1>Solicite seu acesso ao <span>sistema</span>.</h1>
            <p>Depois do cadastro, aguarde a liberacao do administrador para entrar no painel da marcenaria.</p>
        </div>

        <div class="panel-right">
            <div class="box">
                <div class="eyebrow">Novo usuario</div>
                <h2>Criar acesso</h2>
                <p class="hint">Preencha os dados para solicitar entrada no sistema.</p>

                @if (ViewBag.Erro != null)
                {
                    <div class="msg error">@ViewBag.Erro</div>
                }

                @if (ViewBag.Sucesso != null)
                {
                    <div class="msg success">@ViewBag.Sucesso</div>
                }

                @Html.ValidationSummary(true, "", new { @class = "msg error" })

                <form method="post">
                    @Html.AntiForgeryToken()

                    <div class="field">
                        <label for="Nome">Nome</label>
                        @Html.TextBoxFor(m => m.Nome, new { required = "required" })
                        @Html.ValidationMessageFor(m => m.Nome, "", new { @class = "val-error" })
                    </div>

                    <div class="field">
                        <label for="Email">E-mail</label>
                        @Html.TextBoxFor(m => m.Email, new { type = "email", required = "required" })
                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "val-error" })
                    </div>

                    <div class="field">
                        <label for="Senha">Senha</label>
                        @Html.PasswordFor(m => m.Senha, new { required = "required" })
                        @Html.ValidationMessageFor(m => m.Senha, "", new { @class = "val-error" })
                    </div>

                    <button class="btn" type="submit">Cadastrar usuario</button>
                </form>

                <a class="back" href="@Url.Action("Login", "Admin")">Voltar para o login</a>
            </div>
        </div>
    </div>
</body>
</html>
