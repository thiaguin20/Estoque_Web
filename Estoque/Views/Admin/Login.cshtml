@model Estoque.Models.ViewModels.LoginViewModel

@{
    ViewBag.Title = "Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login — Marcenaria</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="@Url.Content("~/Content/bootstrap.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/Site.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/ViewStyles/admin-login.css")" rel="stylesheet" />
</head>
<body>

    <div class="split">

        <!-- LEFT -->
        <div class="panel-left">

            <div class="brand-lockup">
                <div class="brand-icon"><i class="bi bi-tools"></i></div>
                <div>
                    <div class="brand-name">Marcenaria</div>
                    <div class="brand-sub">Sistema de Gestão</div>
                </div>
            </div>

            <div class="left-eyebrow">Plataforma de Estoque</div>

            <h2 class="left-heading">
                Gestão inteligente<br>do seu <span>ateliê</span>.
            </h2>

            <p class="left-desc">
                Controle total sobre materiais, ferramentas e projetos.
                Tudo que sua marcenaria precisa em um único painel.
            </p>

            <div class="features">
                <div class="feature">
                    <div class="feature-dot"><i class="bi bi-boxes"></i></div>
                    <span class="feature-txt">Controle de estoque em tempo real</span>
                </div>
                <div class="feature">
                    <div class="feature-dot"><i class="bi bi-graph-up"></i></div>
                    <span class="feature-txt">Relatórios e dashboards</span>
                </div>
                <div class="feature">
                    <div class="feature-dot"><i class="bi bi-tools"></i></div>
                    <span class="feature-txt">Gestão de ferramentas e insumos</span>
                </div>
                <div class="feature">
                    <div class="feature-dot"><i class="bi bi-shield-check"></i></div>
                    <span class="feature-txt">Acesso seguro por usuário</span>
                </div>
            </div>

            <div class="left-foot">
                <div>
                    <div class="left-stat-num">+800</div>
                    <div class="left-stat-lbl">Itens gerenciados</div>
                </div>
                <div>
                    <div class="left-stat-num">99%</div>
                    <div class="left-stat-lbl">Disponibilidade</div>
                </div>
                <div>
                    <div class="left-stat-num">24/7</div>
                    <div class="left-stat-lbl">Acesso online</div>
                </div>
            </div>

        </div>

        <!-- RIGHT -->
        <div class="panel-right">
            <div class="form-box">

                <div class="form-header">
                    <div class="eyebrow">Acesso ao sistema</div>
                    <h2>Bem-vindo de volta</h2>
                    <p>Acesse o painel de gestão da marcenaria</p>
                </div>

                @if (ViewBag.Erro != null)
                {
                    <div class="error-banner">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        @ViewBag.Erro
                    </div>
                }

                @Html.ValidationSummary(true, "", new { @class = "error-banner" })

                <form method="post">
                    @Html.AntiForgeryToken()

                    <div class="field">
                        <label for="Usuario">E-mail</label>
                        <div class="field-wrap">
                            <i class="bi bi-person-fill ico" aria-hidden="true"></i>
                            @Html.TextBoxFor(m => m.Usuario, new { type = "email", placeholder = "admin.marcenaria@estoque.local", autocomplete = "username", required = "required" })
                        </div>
                        @Html.ValidationMessageFor(m => m.Usuario, "", new { @class = "val-error" })
                    </div>

                    <div class="field">
                        <label for="senhaInput">Senha</label>
                        <div class="field-wrap">
                            <i class="bi bi-lock-fill ico" aria-hidden="true"></i>
                            @Html.PasswordFor(m => m.Senha, new { id = "senhaInput", placeholder = "Digite sua senha", autocomplete = "current-password", required = "required" })
                            <button type="button" class="toggle-pw" onclick="toggleSenha()" aria-label="Mostrar ou ocultar senha">
                                <i class="bi bi-eye-fill" id="eyeIcon" aria-hidden="true"></i>
                            </button>
                        </div>
                        @Html.ValidationMessageFor(m => m.Senha, "", new { @class = "val-error" })
                    </div>

                    <button type="submit" class="btn-login">
                        <i class="bi bi-box-arrow-in-right" aria-hidden="true"></i>
                        Entrar no sistema
                    </button>

                </form>

                <div class="form-foot form-foot-spaced">
                    Ainda nao tem acesso?
                    <a href="@Url.Action("Cadastro", "Admin")" class="link-gold">
                        Cadastrar usuario
                    </a>
                </div>

                <div class="form-divider">
                    <hr /><span>Estoque Marcenaria</span><hr />
                </div>

                <div class="form-foot">
                    <strong>Estoque Marcenaria</strong> &copy; @DateTime.Now.Year &mdash; v2.0
                </div>

            </div>
        </div>

    </div>

    <script>
        function toggleSenha() {
            var input = document.getElementById('senhaInput');
            var icon = document.getElementById('eyeIcon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.className = 'bi bi-eye-slash-fill';
            } else {
                input.type = 'password';
                icon.className = 'bi bi-eye-fill';
            }
        }
    </script>

</body>
</html>

