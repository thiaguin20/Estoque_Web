@model Estoque.Models.Produto

@{
    ViewBag.Title = "Excluir Produto";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Excluir Produto — Marcenaria</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="@Url.Content("~/Content/bootstrap.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/Site.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/ViewStyles/produto-delete.css")" rel="stylesheet" />
</head>
<body>

    <div class="shell">

        <!-- SIDEBAR -->
        <aside class="sidebar">
            <div class="brand">
                <div class="brand-icon"><i class="bi bi-tools"></i></div>
                <div>
                    <div class="brand-name">Marcenaria</div>
                    <div class="brand-sub">Sistema de Gestão</div>
                </div>
            </div>

            <nav class="nav-stack">
                <div class="nav-label">Principal</div>
                <a href="@Url.Action("Index", "Produto")" class="nav-item active">
                    <i class="bi bi-boxes"></i> Estoque
                </a>
                <a href="@Url.Action("Create", "Produto")" class="nav-item">
                    <i class="bi bi-plus-circle"></i> Novo Produto
                </a>
            </nav>

            <div class="sidebar-foot">
                <details class="settings-menu">
                    <summary class="nav-item nav-item-small">
                        <i class="bi bi-gear"></i> Configurações
                    </summary>
                    <div class="settings-panel">
                        <a href="@Url.Action("Logout", "Admin")" class="nav-item nav-item-small">
                            <i class="bi bi-box-arrow-right"></i> Sair
                        </a>
                    </div>
                </details>
            </div>
        </aside>

        <!-- MAIN -->
        <div class="main">

            <!-- TOPBAR -->
            <div class="topbar">
                <span class="topbar-title">Confirmar exclusão</span>
                <a href="@Url.Action("Index", "Produto")" class="btn-back">
                    <i class="bi bi-arrow-left"></i> Voltar ao estoque
                </a>
            </div>

            <!-- CONTENT -->
            <div class="content">

                <div class="hero">
                    <div class="hero-eyebrow">Exclusão de Produto</div>
                    <h1>Remover <span>Produto</span></h1>
                </div>

                <div class="alert-banner">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <div>
                        <strong>Atenção — ação irreversível</strong>
                        <p>Essa ação não pode ser desfeita. O produto será removido permanentemente do sistema.</p>
                    </div>
                </div>

                <div class="prod-card">
                    <div class="prod-card-head">
                        <i class="bi bi-trash3"></i>
                        Produto a ser excluído
                    </div>

                    <div class="prod-card-body">

                        <!-- IMAGE -->
                        <div class="prod-img-panel">
                            @if (!string.IsNullOrEmpty(Model.ImagemUrl))
                            {
                                <img src="@Url.Content(Model.ImagemUrl)" alt="@Model.Nome" />
                            }
                            else
                            {
                                <div class="no-img"><i class="bi bi-image"></i></div>
                            }
                        </div>

                        <!-- INFO -->
                        <div class="prod-info-panel">
                            <div class="info-row">
                                <span class="info-key">ID</span>
                                <span class="info-val"><span class="id-chip">#@Model.Id</span></span>
                            </div>
                            <div class="info-row">
                                <span class="info-key">Nome</span>
                                <span class="info-val">@Model.Nome</span>
                            </div>
                            <div class="info-row">
                                <span class="info-key">Preço</span>
                                <span class="info-val">R$ @Model.Preco.ToString("N2")</span>
                            </div>
                            @if (!string.IsNullOrEmpty(Model.Descricao))
                            {
                                <div class="info-row">
                                    <span class="info-key">Descrição</span>
                                    <span class="info-val" class="text-muted-body">@Model.Descricao</span>
                                </div>
                            }
                        </div>

                    </div>

                    <div class="prod-actions">
                        <a href="@Url.Action("Index", "Produto")" class="btn-cancel">
                            <i class="bi bi-x-lg"></i> Cancelar
                        </a>
                        @using (Html.BeginForm())
                        {
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-confirm-del">
                                <i class="bi bi-trash3-fill"></i> Confirmar Exclusão
                            </button>
                        }
                    </div>

                </div>

            </div>
        </div>
    </div>

</body>
</html>
