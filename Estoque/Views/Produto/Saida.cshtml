@model Estoque.Models.Produto

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <title>Saída de Estoque</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link href="@Url.Content("~/Content/bootstrap.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/Site.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/ViewStyles/produto-saida.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/ViewStyles/mobile.css")" rel="stylesheet" />
</head>
<body>
    <div class="stock-move-page">
        <div class="stock-move-card">
            <h1><i class="bi bi-dash-circle" aria-hidden="true"></i> Saída de Estoque</h1>
            <div class="subtitle">Remover itens do estoque</div>
            <div class="produto">@Model.Nome</div>
            <div class="badge @(Model.Quantidade < 50 ? "low" : Model.Quantidade <= 100 ? "medium" : "high")">
                Atual: @Model.Quantidade
            </div>

            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <label for="quantidadeSaida" class="visually-hidden">Quantidade a retirar</label>
                <input type="number" id="quantidadeSaida" name="quantidade" min="1" step="1" placeholder="Quantidade a retirar" required aria-label="Quantidade a retirar" />

                <div class="actions">
                    <button type="submit" class="btn btn-danger">Confirmar</button>
                    <a href="@Url.Action("Index")" class="btn btn-secondary">Cancelar</a>
                </div>
            }
        </div>
    </div>
</body>
</html>
