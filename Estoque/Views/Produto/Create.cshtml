@model Estoque.Models.Produto

@{
    ViewBag.Title = "Novo Produto";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title — Marcenaria</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="@Url.Content("~/Content/bootstrap.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/Site.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/ViewStyles/produto-create.css")" rel="stylesheet" />
</head>
<body>

    <div class="shell">

        <!-- SIDEBAR -->
        <aside class="sidebar">
            <div class="brand">
                <div class="brand-icon"><i class="bi bi-tools"></i></div>
                <div>
                    <div class="brand-name">Marcenaria</div>
                    <div class="brand-sub">Sistema de Gestão</div>
                </div>
            </div>

            <nav class="nav-stack">
                <div class="nav-label">Principal</div>
                <a href="@Url.Action("Index", "Produto")" class="nav-item">
                    <i class="bi bi-boxes"></i> Estoque
                </a>
                <a href="@Url.Action("Create", "Produto")" class="nav-item active">
                    <i class="bi bi-plus-circle"></i> Novo Produto
                </a>
            </nav>

            <div class="sidebar-foot">
                <details class="settings-menu">
                    <summary class="nav-item nav-item-small">
                        <i class="bi bi-gear"></i> Configurações
                    </summary>
                    <div class="settings-panel">
                        <a href="@Url.Action("Logout", "Admin")" class="nav-item nav-item-small">
                            <i class="bi bi-box-arrow-right"></i> Sair
                        </a>
                    </div>
                </details>
            </div>
        </aside>

        <!-- MAIN -->
        <div class="main">

            <!-- TOPBAR -->
            <div class="topbar">
                <span class="topbar-title">
                    Cadastro de produto
                </span>
                <a href="@Url.Action("Index", "Produto")" class="btn-back">
                    <i class="bi bi-arrow-left"></i> Voltar ao estoque
                </a>
            </div>

            <!-- CONTENT -->
            <div class="content">

                <div class="hero">
                    <div class="hero-eyebrow">Novo Produto</div>
                    <h1>Cadastrar <span>Produto</span></h1>
                </div>

                <div class="form-card">
                    <div class="form-card-head">
                        <i class="bi bi-plus-circle"></i>
                        Preencha os dados do novo produto
                    </div>

                    <div class="form-body">
                        @using (Html.BeginForm("Create", "Produto", FormMethod.Post, new { enctype = "multipart/form-data" }))
                        {
                            @Html.AntiForgeryToken()
                            @Html.ValidationSummary(true)

                            <div class="form-grid">

                                <!-- COLUNA ESQUERDA -->
                                <div class="form-stack">

                                    <div class="field">
                                        <label for="Nome">Nome do Produto</label>
                                        @Html.TextBoxFor(m => m.Nome, new { placeholder = "Ex: Porta de Madeira" })
                                        @Html.ValidationMessageFor(m => m.Nome, "", new { @class = "val-error" })
                                    </div>

                                    <div class="field">
                                        <label for="Preco">Preço (R$)</label>
                                        @Html.TextBoxFor(m => m.Preco, new { placeholder = "Ex: 150.00" })
                                        @Html.ValidationMessageFor(m => m.Preco, "", new { @class = "val-error" })
                                    </div>

                                    <div class="field">
                                        <label for="Quantidade">Quantidade em Estoque</label>
                                        @Html.TextBoxFor(m => m.Quantidade, new { type = "number", min = "0" })
                                        @Html.ValidationMessageFor(m => m.Quantidade, "", new { @class = "val-error" })
                                    </div>

                                </div>

                                <!-- COLUNA DIREITA -->
                                <div>
                                    <div class="field field-upload">
                                        <label for="fotoUpload">Imagem do Produto</label>
                                    </div>
                                    <div class="img-box">
                                        <div class="field field-full">
                                            <input type="file" id="fotoUpload" name="fotoUpload" aria-label="Imagem do produto" />
                                        </div>
                                        <p class="img-hint">
                                            Adicione uma imagem do produto.
                                        </p>
                                    </div>
                                </div>

                            </div>

                            <hr class="form-divider" />

                            <div class="form-actions">
                                <a href="@Url.Action("Index", "Produto")" class="btn-cancel">Cancelar</a>
                                <button type="submit" class="btn-submit">
                                    <i class="bi bi-floppy"></i>
                                    Salvar Produto
                                </button>
                            </div>
                        }
                    </div>
                </div>

            </div>
        </div>
    </div>

</body>
</html>
