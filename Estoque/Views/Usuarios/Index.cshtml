@model IEnumerable<Estoque.Models.Usuario>

@{
    ViewBag.Title = "Usuarios";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Usuarios - Marcenaria</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="@Url.Content("~/Content/bootstrap.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/Site.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/ViewStyles/usuarios-index.css")" rel="stylesheet" />
</head>
<body>
    <div class="shell">
        <aside class="sidebar">
            <div class="brand">
                <div class="brand-icon"><i class="bi bi-tools"></i></div>
                <div>
                    <div class="brand-name">Marcenaria</div>
                    <div class="brand-sub">Sistema de Gestao</div>
                </div>
            </div>

            <div class="nav-label">Principal</div>
            <a href="@Url.Action("Index", "Produto")" class="nav-item">
                <i class="bi bi-boxes"></i> Estoque
            </a>
            <a href="@Url.Action("Index", "Usuarios")" class="nav-item active">
                <i class="bi bi-people"></i> Usuarios
            </a>
            <div class="sidebar-foot">
                <details class="settings-menu">
                    <summary class="nav-item nav-item-small">
                        <i class="bi bi-gear"></i> ConfiguraÃ§Ãµes
                    </summary>
                    <div class="settings-panel">
                        <a href="@Url.Action("Logout", "Admin")" class="nav-item nav-item-small">
                            <i class="bi bi-box-arrow-right"></i> Sair
                        </a>
                    </div>
                </details>
            </div>
        </aside>

        <main class="main">
            <div class="top">
                <div>
                    <div class="eyebrow">Controle de acesso</div>
                    <h1>Usuarios cadastrados</h1>
                </div>
                <a href="@Url.Action("Index", "Produto")" class="btn-back">
                    <i class="bi bi-arrow-left"></i> Voltar ao estoque
                </a>
            </div>

            @if (TempData["Erro"] != null)
            {
                <div class="msg error">@TempData["Erro"]</div>
            }

            @if (TempData["Sucesso"] != null)
            {
                <div class="msg success">@TempData["Sucesso"]</div>
            }

            <div class="card">
                <div class="table-scroll">
                    <table>
                        <thead>
                            <tr>
                                <th>Usuario</th>
                                <th>E-mail</th>
                                <th>Status</th>
                                <th>Acao</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="4" class="empty-cell">
                                        Nenhum usuario cadastrado ainda.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                foreach (var usuario in Model)
                                {
                                    <tr>
                                        <td>
                                            <span class="name">@usuario.Nome</span><br />
                                            <small>@usuario.DataCadastro.ToString("dd/MM/yyyy HH:mm")</small>
                                        </td>
                                        <td>@usuario.Email</td>
                                        <td>
                                            @if (usuario.PodeAcessarAdmin)
                                            {
                                                <span class="badge ok">Liberado</span>
                                            }
                                            else
                                            {
                                                <span class="badge wait">Aguardando</span>
                                            }
                                        </td>
                                        <td>
                                            @using (Html.BeginForm("AlternarPermissao", "Usuarios", new { id = usuario.Id }, FormMethod.Post))
                                            {
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="action">
                                                    @(usuario.PodeAcessarAdmin ? "Bloquear" : "Liberar")
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>
</body>
</html>
