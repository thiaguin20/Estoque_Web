<?xml version="1.0" encoding="utf-8"?>
<configuration xmlns:xdt="http://schemas.microsoft.com/XML-Document-Transform">
  <!--
    Azure App Service deve receber as configuracoes de producao pelo Portal:
    - Connection string "EstoqueContext" apontando para Azure SQL
    - App settings "AdminEmail" e "AdminPasswordHash"

    Assim o Web.config local continua usando LocalDB sem quebrar o ambiente de desenvolvimento.
  -->
  <system.web>
    <compilation xdt:Transform="RemoveAttributes(debug)" />
    <customErrors mode="Off" xdt:Transform="Replace" />
  </system.web>
</configuration>
